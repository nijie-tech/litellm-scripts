# 复制为 .env 并填写。本目录 .env 切勿提交(见下方 .gitignore 提示)。
# 注意:这是【网关容器】的环境;和 scripts/.env(setup 脚本的客户端环境)是两份,
#       但 LITELLM_MASTER_KEY / SILICONFLOW_API_KEY 的【值】要一致。

# ===== Postgres(单容器,测试用) =====
POSTGRES_PASSWORD=换成强随机密码

# ===== 网关核心 =====
LITELLM_MASTER_KEY=sk-生成一个强随机做总钥匙
LITELLM_SALT_KEY=sk-生成一个,用于加密入库的 provider key,【设了就别改】

# ===== 各模型 provider key(填你真实的;模型名要和 config.yaml / routes 文件对应) =====
DEEPSEEK_API_KEY=
MOONSHOT_API_KEY=
DASHSCOPE_API_KEY=
DASHSCOPE_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1

# ===== 语义路由 embedding(SiliconFlow) =====
SILICONFLOW_API_KEY=
